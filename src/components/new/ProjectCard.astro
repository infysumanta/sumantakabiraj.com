---
import type { Project } from '../../data/profile';

interface Props {
  project: Project;
}
const { project } = Astro.props;
---
<details class="pcard" style="border:1px solid var(--bd);border-radius:14px;background:var(--card);margin-bottom:14px;overflow:hidden">
  <summary style="padding:20px;display:flex;align-items:center;justify-content:space-between;gap:16px">
    <div>
      <div style="font-size:17px;font-weight:600;color:var(--fg)">{project.name} <span style="font-weight:400;color:var(--dim);font-size:14px">&middot; {project.year}</span></div>
      <div style="font-size:14.5px;color:var(--fg2);margin-top:6px">{project.blurb}</div>
      <div style="font-size:12.5px;color:var(--dim);margin-top:8px">{project.techline}</div>
    </div>
    <span class="chev" style="flex-shrink:0">&rsaquo;</span>
  </summary>
  <div class="pbody" style="padding:0 20px 22px">
    <p style="margin:0 0 16px;font-size:14.5px;line-height:1.65;color:var(--fg2)">{project.long}</p>
    <ul style="margin:0 0 18px;padding-left:0;list-style:none;display:flex;flex-direction:column;gap:8px">
      {project.features.map((f) => (
        <li style="position:relative;padding-left:18px;font-size:14px;color:var(--fg2)">
          <span style="position:absolute;left:0;color:var(--dim)">&mdash;</span>{f}
        </li>
      ))}
    </ul>
    <div style="display:flex;flex-wrap:wrap;gap:7px;margin-bottom:18px">
      {project.tech.map((t) => (
        <span class="chip" style="font-size:12px;padding:5px 11px;border-radius:16px;background:var(--chip);border:1px solid var(--chipbd);color:var(--chipfg)">{t}</span>
      ))}
    </div>
    <div style="display:flex;gap:10px">
      {project.github && (
        <a class="cta" href={project.github} target="_blank" rel="noreferrer" style="font-size:13px;font-weight:600;padding:9px 16px;border:1px solid var(--bd);border-radius:8px;color:var(--fg)">GitHub</a>
      )}
      {project.demo && (
        <a class="cta" href={project.demo} target="_blank" rel="noreferrer" style="font-size:13px;font-weight:600;padding:9px 16px;border:1px solid var(--bd);border-radius:8px;color:var(--fg)">Live</a>
      )}
    </div>
  </div>
</details>
