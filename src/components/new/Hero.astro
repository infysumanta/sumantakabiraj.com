---
import { HERO, SOCIALS } from '../../data/profile';
---
<section style="max-width:780px;margin:0 auto;padding:96px 28px 64px;position:relative">
  <span data-theme-toggle class="tt" style="position:absolute;top:34px;right:28px;cursor:pointer;font-size:20px;color:var(--dim);user-select:none">
    <span style="display:inline" data-theme-icon="dark">&#9789;</span>
    <span style="display:none" data-theme-icon="light">&#9788;</span>
  </span>
  <h1 style="margin:0 0 10px;font-size:44px;font-weight:800;letter-spacing:-.02em;color:var(--fg)">
    Hey, I'm {HERO.name}
  </h1>
  <p style="margin:0 0 6px;font-size:19px;font-weight:500;color:var(--fg2)">{HERO.role} &middot; {HERO.location}</p>
  <p style="margin:0 0 28px;font-size:16px;color:var(--dim)">Currently building {HERO.building}</p>

  <div style="display:flex;gap:18px;align-items:center">
    <a class="io" href={SOCIALS.github} target="_blank" rel="noreferrer" aria-label="GitHub" style="color:var(--fg2)">
      <svg width="21" height="21" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.7-1.4-1.7-1.1-.8.1-.8.1-.8 1.2.1 1.9 1.3 1.9 1.3 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.3-3.2-.1-.3-.6-1.5.1-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.2 2.9.1 3.2.8.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3Z"/></svg>
    </a>
    <a class="io" href={SOCIALS.twitter} target="_blank" rel="noreferrer" aria-label="X" style="color:var(--fg2)">
      <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor"><path d="M18.24 2h3.3l-7.2 8.2L23 22h-6.6l-5.2-6.8L5.2 22H2l7.7-8.8L2 2h6.8l4.7 6.2L18.24 2Zm-1.2 18h1.8L7 4h-1.9l12 16Z"/></svg>
    </a>
    <a class="io" href={SOCIALS.linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn" style="color:var(--fg2)">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9h4v12H3V9Zm7 0h3.8v1.7h.05c.53-1 1.83-2 3.77-2 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.6c0-1.34-.02-3.07-1.87-3.07-1.87 0-2.16 1.46-2.16 2.97V21h-4V9Z"/></svg>
    </a>
    <a class="io" href={SOCIALS.email} aria-label="Email" style="color:var(--fg2)">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 5h16a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z"/><path d="m3.5 6 8.5 7 8.5-7"/></svg>
    </a>
    <a class="io" href={SOCIALS.cal} target="_blank" rel="noreferrer" aria-label="Book a call" style="color:var(--fg2)">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3.5" y="4.5" width="17" height="16" rx="2"/><path d="M3.5 9h17M8 3v3M16 3v3"/></svg>
    </a>
    <a class="io" href="/sumanta-kabiraj-resume.pdf" download aria-label="Download resume" style="color:var(--fg2)">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3v12m0 0-4.5-4.5M12 15l4.5-4.5"/><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></svg>
    </a>
  </div>
</section>
<script is:inline>
  (function () {
    function sync() {
      var dark = document.documentElement.dataset.theme !== 'light';
      document.querySelectorAll('[data-theme-icon="dark"]').forEach(function (el) { el.style.display = dark ? 'inline' : 'none'; });
      document.querySelectorAll('[data-theme-icon="light"]').forEach(function (el) { el.style.display = dark ? 'none' : 'inline'; });
    }
    sync();
    document.addEventListener('click', function (e) { if (e.target.closest('[data-theme-toggle]')) setTimeout(sync, 0); });
  })();
</script>
