---
import { SOCIALS } from '../../data/profile';
---
<section id="contact" style="max-width:680px;margin:0 auto;padding:56px 28px 40px;border-top:1px solid var(--bd)">
  <h2 style="margin:0 0 12px;font-size:26px;font-weight:700;letter-spacing:-.01em;color:var(--fg)">Let's talk</h2>
  <p style="margin:0 0 22px;font-size:15.5px;color:var(--fg2)">Open to full-time roles and freelance work &mdash; reach out any way that's easiest.</p>
  <div style="display:flex;flex-wrap:wrap;gap:10px">
    <a class="cta" href={SOCIALS.cal} target="_blank" rel="noreferrer" style="font-size:13px;font-weight:600;padding:11px 18px;border:1px solid var(--bd);border-radius:8px;color:var(--fg)">Book a call</a>
    <a class="cta" href={SOCIALS.email} style="font-size:13px;font-weight:600;padding:11px 18px;border:1px solid var(--bd);border-radius:8px;color:var(--fg)">Email</a>
    <a class="cta" href={SOCIALS.linkedin} target="_blank" rel="noreferrer" style="font-size:13px;font-weight:600;padding:11px 18px;border:1px solid var(--bd);border-radius:8px;color:var(--fg)">LinkedIn</a>
    <a class="cta" href={SOCIALS.github} target="_blank" rel="noreferrer" style="font-size:13px;font-weight:600;padding:11px 18px;border:1px solid var(--bd);border-radius:8px;color:var(--fg)">GitHub</a>
    <a class="cta" href="/sumanta-kabiraj-resume.pdf" download style="font-size:13px;font-weight:600;padding:11px 18px;border:1px solid var(--bd);border-radius:8px;color:var(--fg)">Download resume</a>
  </div>
</section>
<footer style="max-width:680px;margin:0 auto;padding:24px 28px 48px;font-size:13px;color:var(--dim)">
  &copy; 2026 Sumanta Kabiraj
</footer>
