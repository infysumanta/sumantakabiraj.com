---
import { getCollection, render } from 'astro:content';
import BaseNew from '../../layouts/BaseNew.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const words = post.body?.trim().split(/\s+/).length ?? 0;
const readMins = Math.max(1, Math.round(words / 200));
---
<BaseNew title={`${post.data.title} — Sumanta Kabiraj`}>
  <article class="art" style="max-width:680px;margin:0 auto;padding:56px 28px 72px">
    <a href="/blog" class="back" style="font-size:14px;color:var(--dim)">&larr; Blog</a>
    <div style="font-size:13px;color:var(--dim);margin:24px 0 10px">
      {post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })} &middot; {readMins} min read
    </div>
    <h1 style="margin:0 0 12px;font-size:32px;font-weight:800;letter-spacing:-.02em;color:var(--fg)">{post.data.title}</h1>
    <p style="margin:0 0 28px;font-size:17px;line-height:1.6;color:var(--fg2)">{post.data.summary}</p>
    <div style="display:flex;align-items:center;gap:12px;padding:18px 0;border-top:1px solid var(--bd);border-bottom:1px solid var(--bd);margin-bottom:36px">
      <div style="width:38px;height:38px;border-radius:50%;background:var(--chip);border:1px solid var(--chipbd);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:var(--chipfg)">SK</div>
      <div>
        <div style="font-size:14px;font-weight:600;color:var(--fg)">Sumanta Kabiraj</div>
        <div style="font-size:12.5px;color:var(--dim)">Full-Stack Developer</div>
      </div>
    </div>
    <Content />
    <div style="margin-top:56px;padding-top:24px;border-top:1px solid var(--bd)">
      <a href="/blog" class="back" style="font-size:14px;color:var(--dim)">&larr; All posts</a>
    </div>
  </article>
</BaseNew>
