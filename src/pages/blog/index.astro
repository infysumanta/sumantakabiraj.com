---
import { getCollection } from 'astro:content';
import BaseNew from '../../layouts/BaseNew.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
---
<BaseNew title="Blog — Sumanta Kabiraj">
  <div style="max-width:1080px;margin:0 auto;padding:56px 28px 64px">
    <a href="/" class="back" style="font-size:14px;color:var(--dim)">&larr; Home</a>
    <h1 style="margin:20px 0 8px;font-size:34px;font-weight:800;letter-spacing:-.02em;color:var(--fg)">Blog</h1>
    <p style="margin:0 0 36px;font-size:15.5px;color:var(--fg2)">Notes on building AI systems, healthcare software and everything in between.</p>
    <div>
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="post" style="display:block;padding:22px 0;border-top:1px solid var(--bd)">
          <div style="font-size:13px;color:var(--dim);margin-bottom:6px">
            {post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </div>
          <div class="ptitle" style="font-size:18px;font-weight:600;color:var(--fg)">{post.data.title}</div>
          <p style="margin:8px 0 0;font-size:14.5px;color:var(--fg2);line-height:1.6">{post.data.summary}</p>
        </a>
      ))}
    </div>
  </div>
</BaseNew>
