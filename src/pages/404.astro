---
import BaseNew from '../layouts/BaseNew.astro';
---
<BaseNew title="404 — Sumanta Kabiraj">
  <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px">
    <div style="max-width:480px;text-align:center">
      <div style="font-size:15px;font-weight:600;letter-spacing:.06em;color:var(--dim);margin-bottom:16px">404</div>
      <h1 style="margin:0 0 12px;font-size:32px;font-weight:800;letter-spacing:-.02em;color:var(--fg)">Page not found</h1>
      <p style="margin:0 0 32px;font-size:15.5px;line-height:1.6;color:var(--fg2)">The page you're looking for doesn't exist or may have moved.</p>
      <a class="cta" href="/" style="display:inline-block;font-size:14px;font-weight:600;padding:11px 20px;border:1px solid var(--bd);border-radius:8px;color:var(--fg);text-decoration:none">&larr; Back home</a>
    </div>
  </div>
</BaseNew>
