---
import Base from '../layouts/Base.astro';
---
<Base title="404 — Sumanta Kabiraj">
  <div data-theme="dark" style="min-height:100vh;background:var(--desk);color:var(--fg);display:flex;align-items:center;justify-content:center;padding:24px">
    <div style="width:100%;max-width:560px;background:var(--bg);border:1px solid var(--bd);border-radius:14px;overflow:hidden;box-shadow:var(--shadow)">
      <div style="display:flex;align-items:center;gap:9px;padding:13px 18px;background:var(--panel);border-bottom:1px solid var(--bd)">
        <span style="width:12px;height:12px;border-radius:50%;background:#ff5f56"></span>
        <span style="width:12px;height:12px;border-radius:50%;background:#ffbd2e"></span>
        <span style="width:12px;height:12px;border-radius:50%;background:#27c93f"></span>
        <span style="margin-left:12px;font-size:12px;color:var(--dim)">sumanta@portfolio: ~ — zsh</span>
      </div>
      <div style="padding:22px 24px 26px;font-size:13.5px;line-height:1.7">
        <div style="color:var(--green)">$ cd <span id="p">.</span></div>
        <div style="color:#ff7a6e;margin-top:8px">zsh: no such file or directory: <span id="p2">.</span></div>
        <div style="color:var(--dim2);margin-top:16px">The page you're looking for doesn't exist.</div>
        <div style="margin-top:20px">
          <a href="/" style="display:inline-block;font-size:13px;font-weight:500;padding:10px 16px;background:var(--green);color:#0b0e0b;border-radius:8px;text-decoration:none">$ cd ~ &nbsp;→ back home</a>
        </div>
      </div>
    </div>
  </div>
  <script is:inline>
    var p = location.pathname;
    document.getElementById('p').textContent = p;
    document.getElementById('p2').textContent = p;
  </script>
</Base>
