---
import BaseNew from '../layouts/BaseNew.astro';
import ProjectCard from '../components/new/ProjectCard.astro';
import { PROJECT_DATA } from '../data/profile';
---
<BaseNew title="Projects — Sumanta Kabiraj">
  <div style="max-width:680px;margin:0 auto;padding:56px 28px 64px">
    <a href="/" class="back" style="font-size:14px;color:var(--dim)">&larr; Home</a>
    <h1 style="margin:20px 0 8px;font-size:34px;font-weight:800;letter-spacing:-.02em;color:var(--fg)">Projects</h1>
    <p style="margin:0 0 36px;font-size:15.5px;color:var(--fg2)">A selection of products I've built.</p>
    {PROJECT_DATA.map((project) => <ProjectCard project={project} />)}
  </div>
</BaseNew>
